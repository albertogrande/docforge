{
  "name": "@docforge/cli",
  "version": "0.1.0-alpha.0",
  "description": "Forge CLI — the `forge` binary (init/check/draft/open-pr/approve/prov/mcp)",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Alberto Grande",
  "homepage": "https://github.com/albertogrande/docforge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albertogrande/docforge.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/albertogrande/docforge/issues"
  },
  "keywords": ["documentation", "docs-as-code", "ai", "agents", "provenance", "mcp", "cli"],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "bin": {
    "forge": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@docforge/core": "workspace:*",
    "@docforge/gates": "workspace:*",
    "@docforge/mcp": "workspace:*",
    "@docforge/producer": "workspace:*",
    "@docforge/provenance": "workspace:*",
    "@docforge/schema": "workspace:*",
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
